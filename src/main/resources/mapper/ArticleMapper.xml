<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mht.mhtblogservice.mapper.ArticleMapper">
    <select id="selectList" resultType="com.mht.mhtblogservice.entity.Article">
        SELECT id, title, content FROM
        t_article
    </select>
    <select id="selectById" parameterType="long" resultType="com.mht.mhtblogservice.entity.Article">
        SELECT id, title,
        content FROM t_article WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.mht.mhtblogservice.entity.Article" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_article (title, content) VALUES (#{title}, #{content})
    </insert>
</mapper>
