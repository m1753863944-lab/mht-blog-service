<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mht.mhtblogservice.mapper.CardConfigMapper">

    <resultMap id="CardConfigResultMap" type="com.mht.mhtblogservice.entity.CardConfig">
        <id property="id" column="id"/>
        <result property="cardIndex" column="card_index"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="iconType" column="icon_type"/>
        <result property="targetUrl" column="target_url"/>
        <result property="status" column="status"/>
    </resultMap>

    <select id="selectActiveConfigs" resultMap="CardConfigResultMap">
        SELECT id, card_index, title, description, icon_type, target_url, status
        FROM blog_card_config_v2
        WHERE status = 1
          AND card_index > 0
        ORDER BY card_index ASC
    </select>

    <select id="selectAllConfigs" resultMap="CardConfigResultMap">
        SELECT id, card_index, title, description, icon_type, target_url, status
        FROM blog_card_config_v2
        ORDER BY status DESC,id desc
    </select>

    <update id="updateSelective" parameterType="com.mht.mhtblogservice.entity.CardConfig">
        UPDATE blog_card_config_v2
        <set>
            <if test="cardIndex != null">card_index = #{cardIndex},</if>
            <if test="title != null">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="targetUrl != null">target_url = #{targetUrl},</if>
            <if test="status != null">status = #{status}</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>
